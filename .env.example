# Symphony — environment configuration
#
# Nothing in this file is required to run Symphony. Every external service is
# a pluggable adapter with a local, in-memory (or on-disk) default. Copy this
# file to `.env` and set only the variables for the adapters you want to turn
# on. See symphony/config.py for the selection logic.

# ---------------------------------------------------------------------------
# LLM provider — default: deterministic MockProvider (no network, no cost)
# ---------------------------------------------------------------------------
# Set SYMPHONY_LLM=qwen to use live Qwen models via DashScope's
# OpenAI-compatible endpoint. Requires DASHSCOPE_API_KEY.
SYMPHONY_LLM=mock
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Cheap/fast tier for the five specialist agents (high call volume).
QWEN_SPECIALIST_MODEL=qwen-turbo
# Top reasoning tier, used only by the Coordinator on genuine deadlock.
QWEN_COORDINATOR_MODEL=qwen-max
# Deterministic seed used by MockProvider when SYMPHONY_LLM=mock.
SYMPHONY_MOCK_SEED=42

# ---------------------------------------------------------------------------
# Event bus — default: in-memory (single-process)
# ---------------------------------------------------------------------------
# Set SYMPHONY_BUS=kafka to publish/consume via ApsaraMQ for Kafka.
SYMPHONY_BUS=memory
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_TOPIC_EVENTS=symphony-events
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# ---------------------------------------------------------------------------
# Blackboard — default: in-memory (single-process)
# ---------------------------------------------------------------------------
# Set SYMPHONY_BLACKBOARD=tablestore to persist world state to Alibaba
# Tablestore instead.
SYMPHONY_BLACKBOARD=memory
TABLESTORE_ENDPOINT=
TABLESTORE_INSTANCE_NAME=
TABLESTORE_ACCESS_KEY_ID=
TABLESTORE_ACCESS_KEY_SECRET=

# ---------------------------------------------------------------------------
# Conflict Graph Explorer — default: local JSON file
# ---------------------------------------------------------------------------
# Set NEO4J_URI to activate the real Neo4j-backed writer/query instead.
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=
SYMPHONY_CONFLICT_GRAPH_JSON_PATH=./conflict_graph.json

# ---------------------------------------------------------------------------
# Ledger
# ---------------------------------------------------------------------------
SYMPHONY_LEDGER_PATH=./ledger.jsonl

# ---------------------------------------------------------------------------
# REST API server (Phase 7)
# ---------------------------------------------------------------------------
SYMPHONY_API_CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Dashboard (Phase 9+) — set in dashboard/.env.local, listed here for reference
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_API_URL=http://localhost:8000
