# Template for the cloud deploy's .env.production -- generated automatically
# by infra/alibaba-cloud/scripts/render-env.sh after `terraform apply`. This
# file documents the shape; don't fill it in by hand unless render-env.sh is
# unavailable.
#
# Consumed by docker-compose.prod.yml's `env_file:` (api container) and
# NEXT_PUBLIC_API_URL (baked into the dashboard image at build time).

SYMPHONY_LLM=mock
DASHSCOPE_API_KEY=

SYMPHONY_BUS=kafka
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_TOPIC_EVENTS=symphony-events

SYMPHONY_BLACKBOARD=tablestore
TABLESTORE_ENDPOINT=
TABLESTORE_INSTANCE_NAME=
TABLESTORE_ACCESS_KEY_ID=
TABLESTORE_ACCESS_KEY_SECRET=

NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=

SYMPHONY_API_CORS_ORIGINS=
NEXT_PUBLIC_API_URL=
